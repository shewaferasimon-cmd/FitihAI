rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Auth UID)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - phoneNumber: string (required) - Verified phone number
    //   - role: string (required) - "user" or "admin"
    //   - isSubscribed: bool (required)
    //   - createdAt: timestamp
    //   - lastLogin: timestamp
    //
    // Collection: documents
    // Document ID: {docId}
    // Fields:
    //   - uid: string (required) - Owner UID
    //   - title: string (required)
    //   - type: string (required)
    //   - content: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
              request.auth.token.email in ['251900000000@fitih.ai', '251999999999@fitih.ai']); 
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role', 'isSubscribed']) &&
             data.uid == request.auth.uid &&
             data.role in ['user', 'admin', 'lawyer'];
    }

    function isValidLawyer(data) {
      return data.keys().hasAll(['uid', 'specialization', 'licenseNumber']) &&
             data.uid == request.auth.uid;
    }

    function isValidConsultation(data) {
      return data.keys().hasAll(['userId', 'lawyerId', 'status', 'date']) &&
             (data.userId == request.auth.uid || data.lawyerId == request.auth.uid) &&
             data.status in ['pending', 'confirmed', 'completed', 'cancelled'] &&
             data.date is timestamp;
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['uid', 'title', 'content']) &&
             data.uid == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.content is string && data.content.size() < 50000;
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['userId', 'text', 'role', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() < 5000 &&
             data.role in ['user', 'model'] &&
             data.createdAt is timestamp;
    }

// Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) || isAdmin();

      match /chats/{chatId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /documents/{docId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidDocument(request.resource.data);
      allow update: if isDocOwner() && isValidDocument(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /lawyers/{lawyerId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin() || (isAuthenticated() && resource.data.isVerified == true);
      allow create, update: if isOwner(lawyerId) && (isAdmin() || isValidLawyer(request.resource.data));
      allow delete: if isAdmin();
    }

    match /consultations/{consultationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.lawyerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidConsultation(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.lawyerId == request.auth.uid || isAdmin()) && isValidConsultation(request.resource.data);
      allow delete: if isAdmin();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
