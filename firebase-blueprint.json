{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user account information and subscription status",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth unique ID" },
        "phoneNumber": { "type": "string", "description": "Verified +251 phone number" },
        "displayName": { "type": "string", "description": "Display name" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Prefer not to say"] },
        "age": { "type": "number" },
        "occupation": { "type": "string" },
        "address": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "lawyer"], "description": "Access level" },
        "isSubscribed": { "type": "boolean", "description": "Subscription status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Last login timestamp" }
      },
      "required": ["uid", "phoneNumber", "role", "isSubscribed"]
    },
    "LawyerProfile": {
      "title": "LawyerProfile",
      "description": "Public profile for practicing lawyers",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "gender": { "type": "string" },
        "age": { "type": "number" },
        "occupation": { "type": "string" },
        "address": { "type": "string" },
        "specialization": { "type": "string" },
        "experience": { "type": "number", "description": "Years of experience" },
        "bio": { "type": "string" },
        "licenseNumber": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "rating": { "type": "number" },
        "hourlyRate": { "type": "number" },
        "availability": { "type": "object" },
        "badge": { "type": "string", "enum": ["Expert", "Pro", "Verified"] }
      },
      "required": ["uid", "displayName", "specialization", "licenseNumber"]
    },
    "Consultation": {
      "title": "Consultation",
      "description": "Booked legal consultation sessions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "lawyerId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "date": { "type": "string", "format": "date-time" },
        "topic": { "type": "string" },
        "price": { "type": "number" },
        "meetingLink": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "lawyerId", "status", "date"]
    },
    "UserDocument": {
      "title": "UserDocument",
      "description": "Generated legal documents saved by the user",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner ID" },
        "title": { "type": "string", "description": "Label for the document" },
        "type": { "type": "string", "description": "Document template type" },
        "content": { "type": "string", "description": "Full text of the document" },
        "metadata": { "type": "object", "description": "Form inputs used to generate" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "content"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Individual chat messages for history",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "text", "role", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User private profile documents"
    },
    "/lawyers/{lawyerId}": {
      "schema": "LawyerProfile",
      "description": "Public profiles of registered lawyers"
    },
    "/consultations/{consultationId}": {
      "schema": "Consultation",
      "description": "Legal consultation bookings"
    },
    "/documents/{docId}": {
      "schema": "UserDocument",
      "description": "Personalized legal documents"
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "Individual chat message history"
    }
  }
}
